{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "fix_heading_tabs spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["headings"],
  "properties": {
    "headings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["number", "title"],
        "properties": {
          "number": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)*$" },
          "title": { "type": "string", "minLength": 1 },
          "xpath": { "type": "string", "minLength": 1 },
          "style": {
            "type": "string",
            "enum": ["Heading1", "Heading2", "Heading3", "Heading4", "Heading5"]
          },
          "ordinal": { "type": "integer", "minimum": 1 },
          "unnumbered": { "type": "boolean", "default": false }
        },
        "oneOf": [
          { "required": ["xpath"] },
          { "required": ["style", "ordinal"] }
        ]
      }
    }
  }
}
