{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_bookmarks spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["figure", "table", "references"],
  "properties": {
    "figure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["style", "xpath", "bookmark_name", "bookmark_id"],
      "properties": {
        "style": { "type": "string", "minLength": 1 },
        "xpath": { "type": "string", "minLength": 1 },
        "bookmark_name": { "type": "string", "pattern": "^fig_[a-z0-9_]+$" },
        "bookmark_id": { "type": "integer", "minimum": 1 }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["style", "xpath", "bookmark_name", "bookmark_id"],
      "properties": {
        "style": { "type": "string", "minLength": 1 },
        "xpath": { "type": "string", "minLength": 1 },
        "bookmark_name": { "type": "string", "pattern": "^tbl_[a-z0-9_]+$" },
        "bookmark_id": { "type": "integer", "minimum": 1 }
      }
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ordinal",
          "xpath",
          "number",
          "bookmark_name",
          "bookmark_id"
        ],
        "properties": {
          "ordinal": { "type": "integer", "minimum": 1 },
          "xpath": { "type": "string", "minLength": 1 },
          "number": { "type": "integer", "minimum": 1 },
          "bookmark_name": { "type": "string", "pattern": "^ref_[a-z0-9_]+$" },
          "bookmark_id": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
