{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "heading_style_map spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["mappings"],
  "properties": {
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["style", "ordinal", "number", "title"],
        "properties": {
          "style": {
            "type": "string",
            "enum": ["Heading1", "Heading2", "Heading3", "Heading4", "Heading5"]
          },
          "ordinal": { "type": "integer", "minimum": 1 },
          "number": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)*$" },
          "title": { "type": "string", "minLength": 1 },
          "unnumbered": { "type": "boolean", "default": false }
        }
      }
    }
  }
}
